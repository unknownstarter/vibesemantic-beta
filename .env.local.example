# VibeSemantic 환경변수 템플릿
# 사용법: cp .env.local.example .env.local → 실제 값 채우기
# ⚠️ .env.local은 gitignore 대상이며 커밋하지 않는다

# ── 필수 ─────────────────────────────────────────────
# Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── 선택 ─────────────────────────────────────────────
# Python 실행 경로. 미지정 시 .venv/bin/python3 → python3 순으로 탐색
# PYTHON_PATH=/usr/local/bin/python3
